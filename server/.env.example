NODE_ENV=development
PORT=3001
APP_NAME=ViroVanta
APP_SLUG=virovanta
SERVICE_NAME=virovanta
API_VERSION=2.0.0
API_BASE_URL=http://localhost:3001
DEFAULT_WEB_ORIGIN=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info

AUTH_PROVIDER=local
ALLOW_OPEN_REGISTRATION=true
JWT_ACCESS_SECRET=change-me-in-production-secret
REPORT_SHARE_TOKEN_SECRET=change-me-in-production-secret
REPORT_INTEGRITY_SECRET=change-me-in-production-secret
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=14
FREE_TIER_DAILY_SCAN_LIMIT=40
MAX_API_KEYS_PER_USER=10

SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_JWKS_URL=
SUPABASE_PASSWORD_RESET_REDIRECT_URL=
SUPABASE_AUTH_TIMEOUT_MS=10000

DATA_STORE_DRIVER=file
DATA_FILE_PATH=./data/virovanta-store.json
DATABASE_URL=
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true
STATE_STORE_TABLE=virovanta_state

QUEUE_PROVIDER=local
RUN_API_SERVER=true
RUN_SCAN_WORKER=true
SCAN_WORKER_MODE=all
SCAN_WORKER_CONCURRENCY=2
QUEUE_NAME=virovanta-scan-jobs
FILE_QUEUE_NAME=virovanta-file-scan-jobs
LINK_QUEUE_NAME=virovanta-link-scan-jobs
QUEUE_ATTEMPTS=3
QUEUE_BACKOFF_MS=2000

# Request limiting is always in-memory. Redis is reserved for BullMQ scan queues only.
RATE_LIMIT_STORE=memory
REDIS_URL=
REDIS_TLS=false
REQUEST_WINDOW_MINUTES=15
REQUESTS_PER_WINDOW=240
AUTH_RATE_LIMIT_WINDOW_MINUTES=15
AUTH_LOGIN_REQUESTS_PER_WINDOW=10
AUTH_MUTATION_REQUESTS_PER_WINDOW=20
AUTH_LOOKUP_REQUESTS_PER_WINDOW=60
URL_SCAN_RATE_LIMIT_WINDOW_MINUTES=15
URL_SCAN_RATE_LIMIT_REQUESTS_PER_WINDOW=30

OBJECT_STORAGE_PROVIDER=none
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_REGION=us-west-000
OBJECT_STORAGE_BUCKET=virovanta
OBJECT_STORAGE_PREFIX=virovanta
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_FORCE_PATH_STYLE=true
OBJECT_STORAGE_SIGNED_URL_TTL_SECONDS=900

UPLOAD_DIR=
MAX_UPLOAD_MB=25
MAX_BATCH_UPLOAD_FILES=10
REPORT_TTL_HOURS=2160
SCAN_HISTORY_LIMIT=2000
SCAN_SLA_TARGET_MINUTES=5
SERVICE_UPTIME_TARGET_PERCENT=99.9

ENABLE_CLAMAV=false
CLAMSCAN_BINARY=clamscan
VIRUSTOTAL_API_KEY=
PUBLIC_QUICK_SCAN_ENABLED=true
PUBLIC_QUICK_SCAN_MAX_UPLOAD_MB=8
PUBLIC_QUICK_SCAN_REQUESTS_PER_WINDOW=30
PUBLIC_QUICK_SCAN_WINDOW_MINUTES=15
PUBLIC_QUICK_SCAN_FINDINGS_LIMIT=8

URL_SCAN_TIMEOUT_MS=12000
URL_SCAN_MAX_REDIRECTS=4
URL_SCAN_MAX_BODY_BYTES=200000
URL_SCAN_MAX_DOWNLOAD_BYTES=5242880
URL_SCAN_USER_AGENT=virovanta/url-scanner
URL_SCAN_ENABLE_BROWSER_RENDER=false
URL_SCAN_BROWSER_TIMEOUT_MS=10000
URL_SCAN_ENABLE_DOWNLOAD_INSPECTION=true
URL_SCAN_STRICT_EGRESS=true
URL_INTEL_TIMEOUT_MS=8000
GOOGLE_SAFE_BROWSING_API_KEY=
URLHAUS_ENABLED=false
URLHAUS_API_BASE_URL=https://urlhaus-api.abuse.ch/v1
